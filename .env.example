# ---- Business Plan Studio — environment configuration ----
# Copy to .env (kept out of git) and fill in for production.

# Initial admin (created once on first boot if no admin exists).
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=ChangeMe123!
ADMIN_FULL_NAME=System Administrator

# JWT secrets — set strong random values in production.
JWT_SECRET_KEY=
JWT_REFRESH_SECRET_KEY=
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# Auth toggles
BP_AUTH_ENABLED=true
BP_COOKIE_SECURE=true        # true in production (HTTPS); false for local http
BP_MAX_FAILED_LOGINS=5
BP_LOCKOUT_MINUTES=15
BP_SEED_DEV_USERS=false      # true seeds a demo finance user (dev only)

# Storage / data
BP_DATA_DIR=
BP_SEED_ON_STARTUP=true
BP_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
